{
  "name": "rts-io",
  "private": true,
  "version": "0.1.0",
  "description": "Browser-based multiplayer .io RTS battle arena with 12 factions",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "server": "npx tsx server/GameServer.ts"
  },
  "keywords": [
    "rts",
    "io-game",
    "multiplayer",
    "arena",
    "webgl",
    "pixijs"
  ],
  "author": "David Ungvari",
  "license": "MIT",
  "dependencies": {
    "pathfinding": "^0.4.18",
    "pixi-viewport": "^6.0.3",
    "pixi.js": "^8.17.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
